# SQLite database path (optional; default: backend/instance/stoopid.db)
# DATABASE_PATH=./instance/stoopid.db

# Reddit API (PRAW)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stoopid-dev/1.0

# Twitter API (optional)
TWITTER_BEARER_TOKEN=

# NewsAPI (optional)
NEWSAPI_KEY=

# Hugging Face (optional, for FinBERT/sentiment)
HUGGINGFACE_TOKEN=

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
